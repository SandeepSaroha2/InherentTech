{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Map env-var name → Vaultwarden item name + field. Mapped against the user's actual vault structure as of 2026-04-30. Reuses NeuralTrade structured items (shared infra) plus a few Ceipal/Supabase web-logins. The sync script merges vault values on top of the existing .env, so anything not in this manifest is left alone.",
  "vaultwardenServer": "https://vault.neurago.ai",
  "outputFile": ".env.local",
  "secrets": [
    {
      "envVar":   "LITELLM_API_KEY",
      "item":     "NeuralTrade LiteLLM",
      "field":    "master_key",
      "required": true
    },
    {
      "envVar":   "ANTHROPIC_API_KEY",
      "item":     "NeuralTrade Anthropic",
      "field":    "api_key",
      "required": false
    },
    {
      "envVar":   "GHCR_TOKEN",
      "item":     "NeuralTrade GHCR PAT",
      "field":    "token",
      "required": false
    },
    {
      "envVar":   "CLOUDFLARE_API_TOKEN",
      "item":     "NeuralTrade Cloudflare",
      "field":    "api_token",
      "required": false
    },
    {
      "envVar":   "CLOUDFLARE_TUNNEL_TOKEN_STAGING",
      "item":     "NeuralTrade Cloudflare",
      "field":    "tunnel_token_staging",
      "required": false
    },
    {
      "envVar":   "CLOUDFLARE_TUNNEL_TOKEN_BETA",
      "item":     "NeuralTrade Cloudflare",
      "field":    "tunnel_token_beta",
      "required": false
    },
    {
      "envVar":   "CLOUDFLARE_TUNNEL_TOKEN_PROD",
      "item":     "NeuralTrade Cloudflare",
      "field":    "tunnel_token_prod",
      "required": false
    },
    {
      "envVar":   "HETZNER_API_TOKEN",
      "item":     "NeuralTrade Hetzner",
      "field":    "api_token",
      "required": false
    },
    {
      "envVar":   "SMTP_HOST",
      "item":     "NeuralTrade SMTP",
      "field":    "host",
      "required": false
    },
    {
      "envVar":   "SMTP_PORT",
      "item":     "NeuralTrade SMTP",
      "field":    "port",
      "required": false
    },
    {
      "envVar":   "SMTP_USER",
      "item":     "NeuralTrade SMTP",
      "field":    "auth_user",
      "required": false
    },
    {
      "envVar":   "SMTP_PASS",
      "item":     "NeuralTrade SMTP",
      "field":    "app_password",
      "required": false
    },
    {
      "envVar":   "SMTP_FROM",
      "item":     "NeuralTrade SMTP",
      "field":    "email",
      "required": false
    },
    {
      "envVar":   "GOOGLE_CLIENT_ID",
      "item":     "NeuralTrade Google OAuth",
      "field":    "client_id",
      "required": false
    },
    {
      "envVar":   "GOOGLE_CLIENT_SECRET",
      "item":     "NeuralTrade Google OAuth",
      "field":    "client_secret",
      "required": false
    },
    {
      "envVar":   "CEIPAL_USERNAME",
      "item":     "talenthire.ceipal.com",
      "field":    "username",
      "required": false
    },
    {
      "envVar":   "CEIPAL_PASSWORD",
      "item":     "talenthire.ceipal.com",
      "field":    "password",
      "required": false
    }
  ],
  "_unmapped_for_now": [
    "DATABASE_URL / DIRECT_URL — not in vault as a structured connection string yet; bring over from current .env",
    "WEBHOOK_SECRET, DEFAULT_ORG_ID — InherentTech-specific, add a 'InherentTech Webhooks' item later",
    "LINKEDIN_*, TWITTER_*, FACEBOOK_* — OAuth dev creds, add as 'InherentTech <Provider> OAuth' items when ready",
    "VONAGE_*, RETELL_*, RESEND_*, STRIPE_* — InherentTech provider creds, add as structured items when ready"
  ]
}
