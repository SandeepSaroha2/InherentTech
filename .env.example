# ─── Supabase ───
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_KEY="eyJ..."

# ─── AI ───
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Communication ───
RETELL_API_KEY=""
VONAGE_API_KEY=""
VONAGE_API_SECRET=""
RESEND_API_KEY=""  # fallback only — SMTP is primary

# ─── SMTP / xgnmail.com ───
SMTP_HOST=box.xgnmail.com
SMTP_PORT=587
SMTP_SECURE=STARTTLS
SMTP_USER=noreply
SMTP_PASS=
SMTP_FROM=noreply@xgnmail.com

# ─── Payments ───
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── n8n ───
N8N_BASE_URL="http://localhost:5678"
N8N_API_KEY=""

# Ceipal ATS
CEIPAL_API_URL=https://api.ceipal.com
CEIPAL_USERNAME=your-ceipal-email@company.com
CEIPAL_PASSWORD=your-ceipal-password
CEIPAL_ENCODED_ACCOUNT=   # from your Ceipal custom job posting URL (segment after /savecustomJobPostingDetails/)
CEIPAL_WIDGET_KEY=        # from your Ceipal custom job posting URL (last segment)
CEIPAL_RECRUITER_EMAIL=   # Ceipal recruitment manager email

# Social Platform OAuth (per-recruiter and org-level job distribution)
# LinkedIn — https://www.linkedin.com/developers/apps/new
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter / X — https://developer.twitter.com/en/portal/projects-and-apps
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook — https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Google Business Profile — https://console.cloud.google.com/
# Enable: "My Business API" / "Business Profile API"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
